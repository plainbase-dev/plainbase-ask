{
  "name": "plainbase-ask",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build:widget": "esbuild src/widget/widget.ts --bundle --minify --outfile=public/widget.js --platform=browser",
    "build": "npm run build:widget",
    "start": "node --env-file=.env --import tsx/esm src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/mistral": "^1.2.8",
    "@ai-sdk/openai": "^1.0.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "ai": "^4.0.0",
    "better-sqlite3": "^9.4.3",
    "crawlee": "^3.16.0",
    "hono": "^4.6.0",
    "marked": "^12.0.0",
    "nodemailer": "^8.0.0",
    "pdf-parse": "^1.1.1",
    "sqlite-vec": "^0.1.6",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
