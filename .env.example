# =============================================
# Support Bot — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- LLM Provider ---
AI_PROVIDER=mistral             # openai | anthropic | mistral | google | ollama
AI_API_KEY=sk-...               # API key for the LLM provider
AI_MODEL=mistral-small-latest   # Chat model name

# --- Embedding Provider ---
# Defaults to AI_PROVIDER if not set. Must be openai, mistral, or google (anthropic has no embedding API).
EMBEDDING_PROVIDER=mistral      # openai | mistral | google
EMBEDDING_API_KEY=sk-...        # API key for the embedding provider (defaults to AI_API_KEY if not set)
EMBEDDING_MODEL=mistral-embed   # Embedding model (defaults: openai → text-embedding-3-small, mistral → mistral-embed, google → text-embedding-004)

# --- Ticket Email (SMTP) ---
TICKET_EMAIL=support@yourcompany.com
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_SECURE=false               # true for port 465
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM=bot@yourcompany.com   # optional, defaults to SMTP_USER

# --- Admin ---
ADMIN_PASSWORD=changeme         # Change this! Used to log into /admin
# NOTE: Set NODE_ENV=production to enable the Secure flag on the session cookie.
# The Secure flag requires HTTPS — do not set production mode without HTTPS.
NODE_ENV=development

# --- Storage ---
DATABASE_PATH=/data/db.sqlite       # Admin DB (agents, conversations, config)
VEC_DATABASE_PATH=/data/vec.sqlite  # Vector DB (documents, chunks, embeddings) — created on first upload

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10           # Max PDF/Markdown upload size in MB

# --- Web Crawler ---
CRAWLEE_STORAGE_DIR=/tmp/crawlee-storage  # Crawlee request queue storage (temp dir, safe to delete)

# --- Server ---
PORT=3000

# --- Litestream (optional S3-compatible backup) ---
# IMPORTANT: The S3 bucket MUST have a private ACL — conversation data is stored in the DB.
# LITESTREAM_S3_BUCKET=your-bucket
# LITESTREAM_S3_PATH=db.sqlite
# LITESTREAM_S3_VEC_PATH=vec.sqlite
# LITESTREAM_ACCESS_KEY_ID=...
# LITESTREAM_SECRET_ACCESS_KEY=...
# LITESTREAM_S3_REGION=us-east-1
# LITESTREAM_S3_ENDPOINT=          # leave blank for AWS; set for Scaleway/R2/MinIO (e.g. https://s3.nl-ams.scw.cloud)

# --- Notes ---
# Changing EMBEDDING_MODEL or EMBEDDING_PROVIDER requires deleting VEC_DATABASE_PATH and re-ingesting all documents.
# The embedding dimension is auto-detected on first upload and fixed for the lifetime of vec.sqlite.
